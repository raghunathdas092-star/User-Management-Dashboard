</head>

<body>

<div class="container">

<h2>Edit User</h2>

<form
action="/edit-user/<%= user._id %>"
method="POST">

<input
type="text"
name="username"
value="<%= user.username %>"
required>

<input
type="email"
name="email"
value="<%= user.email %>"
required>

<button type="submit">
Update User
</button>

</form>

</div>

